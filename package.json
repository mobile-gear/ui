{
  "name": "mobilegear-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage --silent",
    "test:e2e": "cypress open",
    "test:e2e:run": "cypress run",
    "dev:coverage": "cross-env CYPRESS_COVERAGE=true vite",
    "test:e2e:coverage": "cross-env CYPRESS_COVERAGE=true cypress run --quiet",
    "coverage:merge": "node scripts/merge-coverage.mjs",
    "coverage": "npm run test:unit:coverage && start-server-and-test dev:coverage http://localhost:3000 test:e2e:coverage && npm run coverage:merge",
    "coverage:check": "npm run coverage && echo '📊 Coverage report generated'",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.5.1",
    "@stripe/react-stripe-js": "^3.1.1",
    "@stripe/stripe-js": "^5.6.0",
    "@types/lodash": "^4.17.15",
    "axios": "^1.6.2",
    "formik": "^2.4.9",
    "framer-motion": "^12.6.3",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-multi-carousel": "^2.8.5",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.21.1",
    "tailwindcss": "^3.4.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "autoprefixer": "^10.4.16",
    "cross-env": "^10.1.0",
    "cypress": "^15.13.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "nyc": "^18.0.0",
    "postcss": "^8.4.32",
    "prettier": "^3.6.2",
    "start-server-and-test": "^3.0.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.2.0",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^3.0.5"
  }
}
