#!/usr/bin/env sh

echo "🔍 Running coverage check before push..."
echo "📊 Executing: npm run coverage"
echo ""

npm run coverage
TEST_EXIT_CODE=$?

echo ""

if [ $TEST_EXIT_CODE -ne 0 ]; then
  echo "❌ Tests failed! Push cancelled."
  echo "Please fix failing tests before pushing."
  exit 1
fi

COVERAGE=$(npm run coverage:merge 2>&1 | grep "All files" | awk '{print $4}' | sed 's/%//')
echo "📊 Coverage: ${COVERAGE}%"

COVERAGE_NUM=$(echo "$COVERAGE" | sed 's/%//')

if awk "BEGIN {print ($COVERAGE_NUM < 80)}" | grep -q "1"; then
  echo "❌ Coverage ${COVERAGE}% is below 80% threshold"
  echo "Please improve test coverage before pushing."
  exit 1
fi

echo "✅ All tests passed and coverage meets threshold! 🚀"
echo ""
