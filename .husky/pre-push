#!/usr/bin/env sh

echo "🔍 Running coverage check before push..."
npm run coverage:merge > /dev/null 2>&1

COVERAGE=$(npm run coverage:merge 2>&1 | grep "All files" | awk '{print $4}' | sed 's/%//')
echo "📊 Current coverage: ${COVERAGE}%"

# Compare coverage using awk (works on all platforms)
if awk "BEGIN {exit ($COVERAGE < 80)}"; then
  echo "✅ Coverage ${COVERAGE}% meets 80% threshold"
else
  echo "❌ Coverage ${COVERAGE}% is below 80% threshold"
  echo "Please improve test coverage before pushing"
  exit 1
fi

echo "🧹 Running lint..."
npm run lint

echo "✅ Pre-push checks passed! 🚀"
